<Window x:Class="TrayScanStandard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrayScanStandard"
        mc:Ignorable="d"
        xmlns:lang="clr-namespace:TrayScanStandard.Properties"
        Loaded="Window_Loaded"
        Closed="Window_Closed" 
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=local:MainWindow}"
        xmlns:view="clr-namespace:TrayScanStandard.View"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="MainWindow" Height="800" Width="1440">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <!--<ColumnDefinition></ColumnDefinition>-->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <!--<Image  Source="Images/beier.png" Opacity="0.2" Grid.Column="1" Grid.Row="1" ></Image>-->

        <Border CornerRadius="20" 
                Visibility="{Binding ViewModel.HasBackGround}"
                Margin="20" 
                Grid.Column="1" 
                Grid.Row="1">
            <Border.Background>
                <ImageBrush ImageSource="Images/beier.png" Opacity="0.1" />
            </Border.Background>
        </Border>

        <TextBox VerticalAlignment="Center"
                   FontSize="20" 
                   Text="{Binding ViewModel.Saves.TrayScanStandardName, Mode=TwoWay}"
                   HorizontalAlignment="Center">
        </TextBox>
        <!--<TextBlock Grid.Column="1"
           VerticalAlignment="Center"
           HorizontalAlignment="Center"
           FontSize="20"
           Text="{Binding ViewModel.Title}"
           >

        </TextBlock>-->
      
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">

            <!-- <StackPanel></StackPanel> -->
            <!--<Image 
                Grid.Column="1"
                VerticalAlignment="Center"
                Margin="0,5,100,5"
                Source="/Images/catl1.png" 
                HorizontalAlignment="Center"></Image>-->

            <!--<TextBlock 
                VerticalAlignment="Center"
                FontSize="15"
                Text="{x:Static lang:Resources.PLCStatus}"
                Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                ></TextBlock>

            <TextBlock 
                Text="{Binding ViewModel.PlcStatus}"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Foreground="{Binding ViewModel.PlcColor}"
                Margin="10,0,0,0"></TextBlock>-->


            <TextBlock VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Text="{x:Static lang:Resources.CurrentOperator}"
                       Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                       FontSize="15" >
            </TextBlock>

            <TextBlock VerticalAlignment="Center"
                       FontSize="15"
                       Margin="10,0,0,0"
                       Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                       Text="{Binding ViewModel.Username}">
            </TextBlock>

            <!--<Button Click="Button_Click">Test</Button>-->
            <Button Margin="10,0,20,0"
                    Command="{Binding ViewModel.SignOutCommand}"
                    Content="{x:Static lang:Resources.Logout}"
                    VerticalAlignment="Center">
            </Button>

            <ComboBox VerticalAlignment="Center"
                      Margin="0,0,20,0"
                      Width="100"
                      SelectionChanged="SelectLangBox_SelectionChanged"
                      x:Name="SelectLangBox">
                <ComboBoxItem >中文</ComboBoxItem>
                <ComboBoxItem>English</ComboBoxItem>
                <ComboBoxItem>Magyar nyelv</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Visibility="Visible">

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         IsChecked="True"
                         Click="RadioButton_Click">
                电芯条码显示
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         IsChecked="True"
                         x:Name="CameraList"
                         Click="CameraList_Click">
                相机管理界面
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         x:Name="LightBtn"
                         Click="LightBtn_Click">
                光源管理界面
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         x:Name="ZPALgo"
                         Click="ZPALgo_Click">
                扫码日志界面
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         x:Name="BatteryManager"
                         Click="BatteryManager_Click">
                电芯种类管理
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         x:Name="LogDash"
                         Click="LogDash_Click">
                日志窗口
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         x:Name="Setting"
                         Click="Setting_Click">
                程序参数设定
            </RadioButton>

            <RadioButton Style="{StaticResource MenuRadioButtonStyle}" 
                         Cursor="Hand"
                         x:Name="PowerManager"
                         Click="PowerManager_Click">
                用户管理界面   
            </RadioButton>

            <!--<CheckBox HorizontalAlignment="Center" 
                IsChecked="{Binding ViewModel.InsSaves.TestModel, UpdateSourceTrigger=PropertyChanged}"
                Visibility="{Binding ViewModel.View2}"
                Click="CheckBox_Click_1"
              >测试模式</CheckBox>-->

        </StackPanel>

        <Frame Grid.Row="1"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Margin="5,5,25,25"
               x:Name="ContentFrame">       
        </Frame>

        <view:LockScreenView Visibility="{Binding ViewModel.IsLock}"
                             x:Name="LockScreen" 
                             Grid.ColumnSpan="3" 
                             Grid.RowSpan="2">
        </view:LockScreenView>
        
        <view:Busying Visibility="{Binding ViewModel.IsBusy}"
                      Opacity="0.5"
                      Progess="{Binding ViewModel.Progg}"
                      BusyText="{Binding ViewModel.BusyMessage}"
                      x:Name="BusyingScreen"
                      Grid.ColumnSpan="2" 
                      Grid.RowSpan="2">
        </view:Busying>

    </Grid>
</Window>
