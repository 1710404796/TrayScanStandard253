<Page x:Class="TrayScanStandard.View.BatteryManager"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TrayScanStandard.View"
      
      d:DataContext="{d:DesignInstance Type=local:BatteryManager}"
      mc:Ignorable="d"
      Title="BatteryManager" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="5">
            <Button Content="添加电池" Command="{Binding ViewModel.AddPalletCommand}"/>
            <Button Content="删除电池" Command="{Binding ViewModel.DeletePalletCommand}"/>
            <Button Content="保存电池" Command="{Binding ViewModel.SavePalletCommand}"/>
            <TextBlock
                VerticalAlignment="Center"
                FontSize="15"
                Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Width="100"
                Margin="10,0,0,0"
                >产品型号过滤:</TextBlock>
            <TextBox Width="100" Height="30" TextChanged="TextBoxBase_OnTextChanged"></TextBox>
        </StackPanel>
        
        <DataGrid Grid.Row="1" 
                  CanUserAddRows="False"
                  AutoGenerateColumns="False"
                  
                  RowEditEnding="DataGrid_RowEditEnding"
                  CellEditEnding="DataGrid_CellEditEnding"
                  ItemsSource="{Binding ViewModel.Battery}"
                  SelectedItem="{Binding ViewModel.SelectedBattery}"
                  >
            <DataGrid.Columns>
                <DataGridTextColumn Header="电池类型" Binding="{Binding TypeName}"/>
                <DataGridTextColumn IsReadOnly="False" Header="通道数量" Binding="{Binding  Count}"/>
                <DataGridTextColumn IsReadOnly="False" Header="托盘列数" Binding="{Binding  Column}"/>

                <!--<DataGridTemplateColumn Header="算法参数">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="设定"
                                    Tag="{Binding }"  
                                    HorizontalAlignment="Stretch"
                                    Width="Auto"
                                    Click="AlgoSetting_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                
            </DataGrid.Columns>
            
        </DataGrid>
    </Grid>
</Page>
