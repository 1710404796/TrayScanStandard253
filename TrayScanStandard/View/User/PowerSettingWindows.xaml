<Window x:Class="TrayScanStandard.View.User.PowerSettingWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TrayScanStandard.View.User"
        xmlns:lang="clr-namespace:TrayScanStandard.Properties"
        mc:Ignorable="d"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        WindowStartupLocation="CenterScreen"
        Title="权限设定页面" SizeToContent="Height" Width="700"
        Loaded="PowerSettingWindows_OnLoaded">

    <Grid >

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="PowerPanel" Margin="0,0,0,30">

            <TextBlock
                HorizontalAlignment="Center" 
                Margin="0,20,0,20"
                Text="权限设置"
                FontSize="20"/>

        </StackPanel>

        <Button 
            Grid.Row="1"
            HorizontalAlignment="Center" 
            Width="100" 
            Click="ButtonBase_OnClick"
            Content="保存"/>

    </Grid>
</Window>
