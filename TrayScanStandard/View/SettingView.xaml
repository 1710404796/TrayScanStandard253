<Page x:Class="TrayScanStandard.View.SettingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View"
      mc:Ignorable="d" 
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=local:SettingView}"
      Title="程序参数设定">
    <ScrollViewer>

        <Grid Margin="0,50,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1">

                <TextBlock FontSize="15"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,15,0,0">
                    WCSIP：端口
                </TextBlock>
                <TextBox 
                    Width="200" 
                    Margin="0,10,0,0" 
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.WcsIpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock FontSize="15"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,15,0,0">
                    物流线PLCIP地址
                </TextBlock>
                <TextBox 
                    Width="200" 
                    Margin="0,10,0,0" 
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.Saves.PLCIP, Mode=TwoWay}"/>

                <TextBlock 
                    FontSize="15"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,15,0,0">
                    相机个数
                </TextBlock>
                <TextBox 
                    Width="200" 
                    Margin="0,10,0,0" 
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.Saves.CameraCount, Mode=TwoWay}"/>

                <Button 
                    IsEnabled="{Binding ViewModel.CanEditing}"
                    x:Name="SaveButton" 
                    Width="100"
                    Margin="0,20,0,0"
                    Click="SaveButton_Click">保存设定</Button>

            </StackPanel>

            <StackPanel Grid.Column="2">

                <TextBlock
                    FontSize="15"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,15,0,0">
                    系统编号
                </TextBlock>
                <TextBox
                    Width="200"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.Saves.SystemCode,Mode=TwoWay}"/>

                <TextBlock
                    FontSize="15"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,15,0,0">
                    库位号    
                </TextBlock>
                <TextBox
                    Width="200"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.Saves.HouseCode,Mode=TwoWay}"/>

                <TextBlock
                    FontSize="15"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,15,0,0">
                    设备号
                </TextBlock>
                <TextBox
                    Width="200"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.Saves.DeviceCode,Mode=TwoWay}"/>        

            </StackPanel>

            <StackPanel Grid.Column="3">

                <TextBlock 
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Margin="0,10,0,0" 
                    FontSize="15">日志清理时间(天)</TextBlock>
                <TextBox  
                    Margin="0,10,0,0" 
                    Width="200"
                    HorizontalAlignment="Left"
                    Text="{Binding ViewModel.Saves.LogDeleteDay}"/>

                <Button 
                    Width="100" 
                    Margin="0,10,0,0"  
                    Click="SetPower_Click">权限设置</Button>

                <!--<Button 
                    Width="100" 
                    Margin="0,10,0,0"  
                    Click="StationSetting_Click">工位配置</Button>-->

                <CheckBox 
                    Margin="0,10,0,0" 
                    IsChecked="{Binding ViewModel.Saves.CameraEnable}">
                    相机是否启用
                </CheckBox>

                <CheckBox 
                    Margin="0,10,0,0" 
                    IsChecked="{Binding ViewModel.Saves.IsAlgoEnable}">
                    算法是否启用
                </CheckBox>

                <CheckBox 
                    Margin="0,10,0,0" 
                    IsChecked="{Binding ViewModel.IsBackGround}">
                    是否有背景
                </CheckBox>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
