<UserControl x:Class="TrayScanStandard.View.AutoFormGeneratorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrayScanStandard.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="10">
            <TextBlock Text="{Binding Path=Title}" FontWeight="Bold" Margin="0,0,5,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Height="auto">

            <StackPanel Background="Transparent" Margin="10">

                <ItemsControl ItemsSource="{Binding Path=Fields}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <StackPanel Margin="0,5" Orientation="Horizontal">

                                <TextBlock Width="250" VerticalAlignment="Center" Text="{Binding Path=Name}" Margin="0,0,0,0"/>
                                <TextBox Text="{Binding Path=Value, Mode=TwoWay}" Width="200"/>

                            </StackPanel>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>
    </Grid>
</UserControl>
