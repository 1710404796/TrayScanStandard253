<Page x:Class="TrayScanStandard.View.LightManagerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TrayScanStandard.View"
      xmlns:vm="clr-namespace:TrayScanStandard.ViewModel"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=local:LightManagerView}"
      d:DesignHeight="550" d:DesignWidth="800"
      Title="光源管理器">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>        <!-- 标题 -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="5" Padding="10">
            <TextBlock Text="光源管理配置" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Border>        <!-- 表格 -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" Margin="0,15,0,0" CornerRadius="3">
            <DataGrid ItemsSource="{Binding ViewModel.LightInfos}"
                    SelectedItem="{Binding ViewModel.SelectedLightInfo}"
                    AutoGenerateColumns="False" 
                    CanUserAddRows="False"
                    IsReadOnly="True" 
                    SelectionMode="Single"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    BorderThickness="0"
                    GridLinesVisibility="All"
                    HeadersVisibility="Column">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="COM 端口" Binding="{Binding Com}" Width="*"/>
                    <DataGridTextColumn Header="光源值 (逗号分隔)" Binding="{Binding ValuesString}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>        <!-- 错误信息 -->
        <TextBlock Grid.Row="2" 
                 Text="{Binding ErrorMessage}" 
                 Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" 
                 Margin="0,10,0,0" 
                 FontSize="12"
                 TextWrapping="Wrap">
            <TextBlock.Visibility>
                <Binding Path="ErrorMessage">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter />
                    </Binding.Converter>
                </Binding>
            </TextBlock.Visibility>
         </TextBlock>        <!-- 操作区域统一布局 - 使用统一的界面风格和对齐方式 -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 添加光源区域 -->
            <GroupBox Grid.Column="0" Header="添加新光源" Margin="0,0,5,0" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- COM 端口选择 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="COM 端口:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"
                               HorizontalAlignment="Right"/>
                               
                    <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding ViewModel.AvailableComPorts}" 
                                  SelectedItem="{Binding ViewModel.NewComPort}"
                                  IsEditable="True" 
                                  Padding="5,5" 
                                  Margin="0,0,5,0"/>
                        <Button Grid.Column="1" 
                                Content="刷新" 
                                Command="{Binding ViewModel.RefreshAvailableComPortsCommand}"
                                Padding="10,5" 
                                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" 
                                BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    
                    <!-- 光源值输入 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="光源值:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"
                               HorizontalAlignment="Right"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding ViewModel.NewValuesString, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="5,5" 
                             Margin="0,0,0,10"/>
                             
                    <!-- 帮助提示 -->
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="使用逗号分隔多个值 (例如: 100,120,150)" 
                               Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}"
                               FontSize="11" 
                               VerticalAlignment="Bottom" 
                               Margin="5,0,0,0" 
                               HorizontalAlignment="Left"
                               Opacity="0.7"/>
                             
                    <!-- 添加按钮 -->
                    <Button Grid.Row="2" Grid.Column="1" 
                            Content="添加光源" 
                            Command="{Binding ViewModel.AddLightCommand}" 
                            Padding="15,8" 
                            Background="{DynamicResource SystemControlHighlightAccentBrush}" 
                            Foreground="{DynamicResource SystemControlHighlightAltChromeWhiteBrush}" 
                            BorderThickness="0"
                            HorizontalAlignment="Right">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </GroupBox>
            
            <!-- 编辑光源区域 -->
            <GroupBox Grid.Column="1" Header="编辑选中光源" Margin="5,0,0,0" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- COM 端口编辑 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="COM 端口:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"
                               HorizontalAlignment="Right"/>
                               
                    <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding ViewModel.AvailableComPorts}" 
                                  SelectedItem="{Binding ViewModel.EditComPort}"
                                  Text="{Binding ViewModel.EditComPort, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" 
                                  Padding="5,5" 
                                  Margin="0,0,5,0"/>
                        <Button Grid.Column="1" 
                                Content="刷新" 
                                Command="{Binding ViewModel.RefreshAvailableComPortsCommand}"
                                Padding="10,5" 
                                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" 
                                BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    
                    <!-- 光源值编辑 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="光源值:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"
                               HorizontalAlignment="Right"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding ViewModel.EditValuesString, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="5,5" 
                             Margin="0,0,0,10"/>
                             
                    <!-- 帮助提示 -->
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="使用逗号分隔多个值 (例如: 100,120,150)" 
                               Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}"
                               FontSize="11" 
                               VerticalAlignment="Bottom" 
                               Margin="5,0,0,0" 
                               HorizontalAlignment="Left"
                               Opacity="0.7"/>
                    
                    <!-- 编辑按钮组 -->
                    <StackPanel Grid.Row="2" Grid.Column="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button Content="保存修改" 
                                Command="{Binding ViewModel.EditLightCommand}" 
                                Padding="15,8" 
                                Background="{DynamicResource SystemControlHighlightAccentBrush}" 
                                Foreground="{DynamicResource SystemControlHighlightAltChromeWhiteBrush}" 
                                BorderThickness="0"
                                Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Button Content="删除光源" 
                                Command="{Binding ViewModel.DeleteLightCommand}" 
                                Padding="15,8" 
                                Background="{DynamicResource SystemControlErrorTextForegroundBrush}" 
                                Foreground="{DynamicResource SystemControlHighlightAltChromeWhiteBrush}" 
                                BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Page>