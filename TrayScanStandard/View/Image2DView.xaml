<UserControl x:Class="TrayScanStandard.View.Image2DView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance Type=local:Image2DView}"
      Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
      d:DesignHeight="450" d:DesignWidth="800"
      >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition ></ColumnDefinition>
            <ColumnDefinition Width="200"></ColumnDefinition>

        </Grid.ColumnDefinitions>
        <Grid x:Name="ImgGrid">
            <ScrollViewer
                HorizontalScrollBarVisibility="Auto" 
VerticalScrollBarVisibility="Auto"
            >
                <local:ResizeAbleImage
                x:Name="img2d"
                Source="{Binding ViewModel.ResultImg}">
                </local:ResizeAbleImage>

            </ScrollViewer>

        </Grid>
        <Border
            x:Name="ImgBorder"
            Grid.Column="1"
BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}"
            
            BorderThickness="2,0,0,0">

            <ScrollViewer>
                <StackPanel 
            Orientation="Vertical"
            HorizontalAlignment="Center"        
                    >
                    <ComboBox Width="123.6" 
                          SelectedIndex="{Binding ViewModel.SelectIdx}"
                          ItemsSource="{Binding ViewModel.BatteryInfos}"
                DisplayMemberPath="TypeName" 
                          
                          SelectionChanged="ComboBox_SelectionChanged"
                          
                          >

                    </ComboBox>


                    <Button 
    Width="123.6"
        Margin="0,19.02,0,0"
    x:Name="DebugCapture"
    Content="{x:Static lang:Resources.DebuggingQRCodeScanning}"
    Command="{Binding ViewModel.DebugCaptureCommand}"
    ></Button>
                    <TextBox 
Width="123.6"
    Margin="0,19.02,0,0"
Text="{Binding ViewModel.DebugExpoure}"
></TextBox>
                    <Button 
                Width="123.6"
                        Margin="0,19.02,0,0"
                x:Name="Capture"
                Content="{x:Static lang:Resources.Capture}"
                Command="{Binding ViewModel.CaptureCommand}" Click="Capture_Click_1"
                ></Button>

                    <Button 
Width="123.6"
        Margin="0,19.02,0,0"
x:Name="Detect"
Content="检测"
Command="{Binding ViewModel.DetectCommand}" 
></Button>
                    <!--<TextBlock Margin="10,0,0,0" Text="{Binding ViewMode.RatioText}"  FontSize="24"/>-->
                    <Button 
    Width="123.6"
                        Margin="0,19.02,0,0"
    x:Name="SetCam"
    Content="{x:Static lang:Resources.SetParameters}"
    Click="SetCam_Click"
    ></Button>

                    <Button 
    Width="123.6"
                        Margin="0,19.02,0,0"
    x:Name="AddBorder"
    Content="{x:Static lang:Resources.AddSelectionBox}"
    Click="AddBorder_Click"
    ></Button>

                    <Button 
Width="123.6"
                    Margin="0,19.02,0,0"
x:Name="SaveBtn"
Content="{x:Static lang:Resources.SaveSettings}"
Click="SaveBtn_Click"
></Button>
                    <Border
BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        Margin="0,19.02,0,0"
            
            BorderThickness="0,2,0,0" />
                    <TextBlock Width="40"
                        Margin="0,19.02,0,0"
         Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center">Top:</TextBlock>
                    <TextBox  
                        TextChanged="TopBox_TextChanged"
                        x:Name="TopBox" Text="{Binding ViewModel.SelectBarCodeRegionInfo.Top, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>

                    <TextBlock
                        Margin="0,19.02,0,0"
         Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                               HorizontalAlignment="Left"
                        
                        Width="40" VerticalAlignment="Center">Left:</TextBlock>
                    <TextBox  x:Name="LeftBox" 
               TextChanged="TopBox_TextChanged"
                              
                              
                              Text="{Binding ViewModel.SelectBarCodeRegionInfo.Left, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>

                    <TextBlock
               Margin="0,19.02,0,0"
Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                      HorizontalAlignment="Left"
               
               Width="40" VerticalAlignment="Center">Width:</TextBlock>
                    <TextBox  x:Name="WidthBox" 
               TextChanged="TopBox_TextChanged"
                          
                          Text="{Binding ViewModel.SelectBarCodeRegionInfo.Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>

                    <TextBlock Width="60"
               Margin="0,19.02,0,0"
Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center">Height:</TextBlock>
                    <TextBox  
               TextChanged="TopBox_TextChanged"
               x:Name="HeightBox" Text="{Binding ViewModel.SelectBarCodeRegionInfo.Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                    <TextBlock Width="60"
               Margin="0,19.02,0,0"
Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center">Channel:</TextBlock>
                    <TextBox  
                    TextChanged="ChannelBox_TextChanged"
               x:Name="ChannelBox" Text="{Binding ViewModel.SelectBarCodeRegionInfo.ChannelIdx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>

                    <Button 
               Margin="0,19.02,0,0"
    Width="123.6"
                    
                    Click="Delete_Border_Click" Content="{x:Static lang:Resources.DeleteTheSelectedBox}"></Button>
                    <TextBlock Margin="0,19.02,0,0" Text="{Binding ViewModel.RatioText, Mode=TwoWay}" TextWrapping="Wrap"></TextBlock>
                    <Button Margin="0,19.02,0,0"  x:Name="Clear" Click="Clear_Click" Content="{x:Static lang:Resources.ClearDebuggingData}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
