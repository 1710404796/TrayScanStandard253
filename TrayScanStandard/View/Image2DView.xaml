<UserControl x:Class="TrayScanStandard.View.Image2DView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance Type=local:Image2DView}"
      Loaded="UserControl_Loaded"
      Unloaded="UserControl_Unloaded"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition ></ColumnDefinition>
            <ColumnDefinition Width="200"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid x:Name="ImgGrid">
 
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">

                <local:ResizeAbleImage x:Name="img2d" Source="{Binding ViewModel.ResultImg}"/>

            </ScrollViewer>

        </Grid>

        <Border
            x:Name="ImgBorder"
            Grid.Column="1"
            BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}"
            BorderThickness="2,0,0,0">

            <ScrollViewer>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

                    <TextBlock Width="123.6" 
                            Margin="0,19.02,0,0"
                            Text="电池方案:"
                            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                    <ComboBox Width="123.6" 
                          SelectedIndex="{Binding ViewModel.SelectIdx}"
                          ItemsSource="{Binding ViewModel.BatteryInfos}"
                          DisplayMemberPath="TypeName" 
                          SelectionChanged="ComboBox_SelectionChanged">
                    </ComboBox>


                    <!--<Button 
                            Width="123.6"
                            Margin="0,19.02,0,0"
                            x:Name="DebugCapture"
                            Content="{x:Static lang:Resources.DebuggingQRCodeScanning}"
                            Command="{Binding ViewModel.DebugCaptureCommand}"
                            ></Button>-->

                    <TextBlock Width="123.6"
                        Margin="0,19.02,0,0"
                        Text="调试曝光:"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"/>
                    <TextBox Width="123.6"
                        Margin="0,19.02,0,0"
                        Text="{Binding ViewModel.DebugExpoure}"/>

                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="Capture"
                        Command="{Binding ViewModel.CaptureCommand}" 
                        Content="拍摄"/>

                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="Detect"
                        Command="{Binding ViewModel.DetectCommand}" 
                        Content="检测"/>


                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="AutoRoi"
                        Content="ROI自动框定"
                        Click="AutoRoi_Click" />        

                    <TextBlock Width="123.6"
                        Margin="0,10,0,0"
                        Text="自动ROI边距(像素):"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" />
                    
                    <TextBox Width="123.6"
                        Height="25"
                        Margin="0,5,0,0"
                        Text="{Binding ViewModel.RoiPadding, Mode=TwoWay}"
                        HorizontalAlignment="Center"/>

                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="SortRoi"
                        Content="ROI自动排序整理"
                        Click="SortRoi_Click"/>

                    <!--<TextBlock Margin="10,0,0,0" Text="{Binding ViewMode.RatioText}"  FontSize="24"/>-->
                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="SetCam"
                        Content="设置参数"
                        Click="SetCam_Click"/>

                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="AddBorder"
                        Content="添加选定框"
                        Click="AddBorder_Click"/>

                    <Button Width="123.6"
                        Margin="0,19.02,0,0"
                        x:Name="SaveBtn"
                        Content="保存设定"
                        Click="SaveBtn_Click"/>

                    <Border Margin="0,19.02,0,0"
                        BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        BorderThickness="0,2,0,0" />

                    <TextBlock Width="40"
                        Margin="0,19.02,0,0"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">上:</TextBlock>
                    <TextBox  x:Name="TopBox" 
                        TextChanged="TopBox_TextChanged"
                        Text="{Binding ViewModel.SelectBarCodeRegionInfo.Top, 
                        Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,19.02,0,0"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        HorizontalAlignment="Left"
                        Width="40" VerticalAlignment="Center">左:</TextBlock>
                    <TextBox  x:Name="LeftBox" 
                        TextChanged="TopBox_TextChanged"
                        Text="{Binding ViewModel.SelectBarCodeRegionInfo.Left, 
                        Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,19.02,0,0"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        HorizontalAlignment="Left"
                        Width="40" VerticalAlignment="Center">宽:</TextBlock>
                    <TextBox  x:Name="WidthBox" 
                        TextChanged="TopBox_TextChanged"
                        Text="{Binding ViewModel.SelectBarCodeRegionInfo.Width, Mode=TwoWay, 
                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Width="60"
                        Margin="0,19.02,0,0"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">高:</TextBlock>
                    <TextBox x:Name="HeightBox" 
                        TextChanged="TopBox_TextChanged"
                        Text="{Binding ViewModel.SelectBarCodeRegionInfo.Height, Mode=TwoWay, 
                        UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Width="60"
                        Margin="0,19.02,0,0"
                        Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">通道:</TextBlock>
                    <TextBox x:Name="ChannelBox"
                        TextChanged="ChannelBox_TextChanged"
                        Text="{Binding ViewModel.SelectBarCodeRegionInfo.ChannelIdx, Mode=TwoWay, 
                        UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 批量设置边框尺寸 -->
                    <Border BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}" 
                            BorderThickness="0,2,0,0" 
                            Margin="0,10,0,5"/>
                    
                    <TextBlock Margin="0,10,0,5"
                               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                               FontWeight="Bold"
                               Text="批量设置尺寸:"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                        <TextBlock Width="40"
                                   Margin="0,0,5,0"
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                                   VerticalAlignment="Center">宽度:</TextBlock>
                        <TextBox x:Name="BatchWidthBox" 
                                 Width="80"
                                 Text="{Binding ViewModel.BatchWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                        <TextBlock Width="40"
                                   Margin="0,0,5,0"
                                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                                   VerticalAlignment="Center">高度:</TextBlock>
                        <TextBox x:Name="BatchHeightBox" 
                                 Width="80"
                                 Text="{Binding ViewModel.BatchHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    
                    <Button Margin="0,5,0,10"
                            Width="120"
                            Click="ApplyBatchSize_Click" 
                            Content="应用到所有边框"/>

                    <Button Margin="0,19.02,0,0"
                            Width="123.6"
                            x:Name="DeleteBtn"
                            Content="删除该选定框"
                            Click="Delete_Border_Click"/>

                    <Button Margin="0,19.02,0,0"
                            Width="123.6"
                            x:Name="ClearAllBoxesBtn"
                            Content="清理所有选定框"
                            Click="ClearAllBoxes_Click"/>

                    <TextBlock Margin="0,19.02,0,0" Text="{Binding ViewModel.RatioText, Mode=TwoWay}" TextWrapping="Wrap"/>
                    <!--<Button Margin="0,19.02,0,0"  x:Name="Clear" Click="Clear_Click" Content="清除调试数据"/>-->
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
