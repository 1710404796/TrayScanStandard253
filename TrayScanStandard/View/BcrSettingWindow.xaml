<Window x:Class="TrayScanStandard.View.BcrSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrayScanStandard.View"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:lang="clr-namespace:TrayScanStandard.Properties"
        mc:Ignorable="d"         
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="相机设置" Height="640" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock FontSize="24" Text="相机设置"/>
            
            <!-- Camera Type Selection -->
            <StackPanel 
                VerticalAlignment="Center"
                Margin="0,30,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Width="160"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Text="相机类型">:</TextBlock>
                <ComboBox
                    Name="CameraTypeCombo"
                    Width="250"
                    SelectionChanged="CameraType_SelectionChanged">
                    <ComboBoxItem Content="HikVision"/>
                    <ComboBoxItem Content="Huarui"/>
                    <!-- Add other camera types here -->
                </ComboBox>
            </StackPanel>
            
            <!-- Connection Type -->
            <StackPanel 
                VerticalAlignment="Center"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Width="160"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Text="连接方式">:</TextBlock>
                <ComboBox
                    Name="ConnectionTypeCombo"
                    Width="250"
                    SelectionChanged="ConnectionType_SelectionChanged">
                    <ComboBoxItem Content="Key"/>
                    <ComboBoxItem Content="IP"/>
                    <ComboBoxItem Content="Serial"/>
                </ComboBox>
            </StackPanel>
            
            <!-- Connection Value -->
            <StackPanel 
                VerticalAlignment="Center"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Width="160"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Text="连接值">:</TextBlock>
                <ui:AutoSuggestBox
                    Name="ConnectionValueBox"
                    Width="250">
                </ui:AutoSuggestBox>
            </StackPanel>
            
            <!-- Exposure -->
            <StackPanel 
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Width="160"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Text="曝光:"/>
                <TextBox 
                    Width="250"
                    Height="150"
                    Name="ExpPattern"
                    TextWrapping="Wrap"
                    AcceptsReturn="True">
                </TextBox>
            </StackPanel>
            
            <!-- Backup Exposure -->
            <StackPanel 
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Width="160"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                    Text="备用曝光">:</TextBlock>
                <TextBox 
                    Width="250"
                    Height="150"
                    Name="ExpBackupPattern"
                    TextWrapping="Wrap"
                    AcceptsReturn="True">
                </TextBox>
            </StackPanel>
            
            <!-- Save Button -->
            <Button Width="100" 
                    Margin="0,15,0,0" 
                    Click="ButtonBase_OnClick" 
                    HorizontalAlignment="Center"
                    Content="保存"/>

        </StackPanel>
    </Grid>
</Window>
