<UserControl x:Class="TrayScanStandard.View.BcrBorder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrayScanStandard.View"
             xmlns:lang="clr-namespace:TrayScanStandard.Properties"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border CornerRadius="10" 
             BorderThickness="2" 
             Padding="10"
                Background="Transparent"
             BorderBrush="{Binding ViewModel.BorderBrush}"
             >
            <!-- BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}" -->

            <StackPanel VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                       
         >
                <StackPanel 
                     Orientation="Horizontal"
                    >
                    <TextBlock HorizontalAlignment="Center"
                            FontSize="20"
                            Margin="5"
                            Text="{Binding ViewModel.ConnectText}"
                            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                 ></TextBlock>

                    <TextBlock HorizontalAlignment="Center"
           FontSize="20"
           Margin="5"
           Text="{Binding ViewModel.Code}"
           Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
></TextBlock>
                </StackPanel>
                <Viewbox 
                    IsHitTestVisible="False"
                    x:Name="camview"
                    Width="200" Height="200">
                    
                </Viewbox>
                <StackPanel Orientation="Horizontal"
                         Margin="0,20,0,0">
                    <Button Click="Reset_Click" Width="100"
                         Name="Reset"
                         HorizontalAlignment="Center"
                        Content="{x:Static lang:Resources.Reconnect}"
                 ></Button>
                    <Button Click="Button_Click" Width="100"
                         HorizontalAlignment="Center"
                            Content="{x:Static lang:Resources.SetUp}"
                 ></Button>
                </StackPanel>

            </StackPanel>

        </Border>
    </Grid>
</UserControl>
