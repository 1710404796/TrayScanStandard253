<Page x:Class="TrayScanStandard.View.DataDisplayView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View"
      mc:Ignorable="d" 
      Loaded="Page_Loaded"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      
      d:DataContext="{d:DesignInstance Type=local:DataDisplayView}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DataDisplayView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition ></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock
                FontSize="24"
                Width="50"
                
                 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                >OK:</TextBlock>
            <TextBlock 
                FontSize="24"
                Width="100"
                
                 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="{Binding ViewModel.OkCnt}"></TextBlock>
            <TextBlock
                FontSize="24"
                MinWidth="110"
                Text="{x:Static lang:Resources.ScanNG}"
                
                 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                >: </TextBlock>
            <TextBlock 
                FontSize="24"
                Width="100"
                
                 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="{Binding ViewModel.NGCnt}"></TextBlock>
            <TextBlock
                FontSize="24"
                MinWidth="180"
                Text="{x:Static lang:Resources.VerificationNG}"
                
                 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                >: </TextBlock>
            <TextBlock 
                Width="100"
                FontSize="24"
                
                 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="{Binding ViewModel.NG2Cnt}"></TextBlock>
            <Button Margin="10,0,0,0" Click="Button_Click"> 保存并重置</Button>
            <Button Margin="10,0,0,0" x:Name="ExportCsv" Click="ExportCsv_Click"> 导出为csv</Button>
        </StackPanel>

        <DataGrid Grid.Row="1" 
          CanUserAddRows="False"
          AutoGenerateColumns="False"
          ItemsSource="{Binding ViewModel.OkNGLogs}"
>
            <DataGrid.Columns>
                <DataGridTextColumn
                    Header="{x:Static lang:Resources.RecordTime}"
                                    Binding="{Binding EndTime}" ></DataGridTextColumn>
                <DataGridTextColumn Header="ok"
                                    
                                    Binding="{Binding OKCnt}" ></DataGridTextColumn>
                <DataGridTextColumn 
                    Header="{x:Static lang:Resources.ScanNG}" Binding="{Binding NG1Cnt}"></DataGridTextColumn>
                <DataGridTextColumn 
                    Header="{x:Static lang:Resources.VerificationNG}" Binding="{Binding NG2Cnt}"></DataGridTextColumn>
               
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
