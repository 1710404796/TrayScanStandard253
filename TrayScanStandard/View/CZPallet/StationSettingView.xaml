<Window x:Class="TrayScanStandard.View.CZPallet.StationSettingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
        mc:Ignorable="d"
        
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
        
                xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="DiaosuStage" Height="760" Width="1150"
        
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition/>
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <StackPanel 
        Margin="10"
        VerticalAlignment="Center" HorizontalAlignment="Center" 
                Orientation="Horizontal">

            <TextBlock 
            Width="100"
            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            Text="{x:Static lang:Resources.InternalNumber}"
            
            
            ></TextBlock>
            <TextBlock 
            Width="150"
            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            TextAlignment="Center"
            Text="{x:Static lang:Resources.Name}"
            
            ></TextBlock>
            <TextBlock 
            Width="150"
            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            TextAlignment="Center"
            Text="{x:Static lang:Resources.BarcodeScannerIP}"
            
            ></TextBlock>
            <TextBlock 
            Width="150"
            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            TextAlignment="Center"
            Text="{x:Static lang:Resources.WorkstationNumber}"
            
            ></TextBlock>
            <TextBlock 
            Width="150"
            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            TextAlignment="Center"
            Text="{x:Static lang:Resources.TrayType}"
            
            ></TextBlock>
            <TextBlock 
            Width="150"
            Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            TextAlignment="Center"
            Text="{x:Static lang:Resources.ChannelCount}"
            
            ></TextBlock>
            <TextBlock 
Width="150"
Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
TextAlignment="Center"
            Text="{x:Static lang:Resources.TrayColumnCount}"
            
></TextBlock>
            <TextBlock 
Width="100"
Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
TextAlignment="Center"
            Text="{x:Static lang:Resources.Enable}"
            
></TextBlock>
        </StackPanel>

        <ScrollViewer 
        Grid.Row="1"
        >

            <StackPanel 
        Orientation="Vertical" 
        HorizontalAlignment="Center"
        Margin="10"
        Name="DiaoPanel"
        Grid.Row="1"
        >
            </StackPanel>
        </ScrollViewer>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="2">

            <Button Width="100" Click="Button_Click">保存</Button>
        </StackPanel>
    </Grid>
</Window>
