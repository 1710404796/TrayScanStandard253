<UserControl x:Class="TrayScanStandard.View.CZPallet.PalletRuleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=local:PalletRuleControl}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="10"
            BorderThickness="2"
            Margin="10"
                BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}">

        <Grid Margin="10">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel
         Margin="0,10,0,0"
         HorizontalAlignment="Center"
         Orientation="Horizontal"
         >
                    <TextBlock
             Width="100"
               Text="{x:Static lang:Resources.TrayRuleName}"
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             VerticalAlignment="Center"
             >
                    </TextBlock>
                    <TextBox
             Width="150"
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             Text="{Binding PalletTypeRule.Name}"
             x:Name="PalletRuleName"
             >

                    </TextBox>

                </StackPanel>
                <StackPanel
         Margin="0,10,0,0"
         HorizontalAlignment="Center"
         Orientation="Horizontal"
         >
                    <TextBlock
             Width="100"
             VerticalAlignment="Center"
               Text="{x:Static lang:Resources.TrayRegex}"
                 
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             >

                    </TextBlock>
                    <TextBox
             Width="150"
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             Text="{Binding PalletTypeRule.PalletRule}"
             x:Name="PalletRegex">

                    </TextBox>
                </StackPanel>

                <StackPanel
         Margin="0,10,0,0"
         HorizontalAlignment="Center"
         Orientation="Horizontal"
         >
                    <TextBlock
             Width="100"
               Text="{x:Static lang:Resources.TrayChannelCount}"
                 
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             VerticalAlignment="Center"
             >

                    </TextBlock>
                    <TextBox
             Width="150"
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             Text="{Binding PalletTypeRule.BatteryNum}"
             x:Name="PalletFakeCode">

                    </TextBox>
                </StackPanel>

                <StackPanel
         Margin="0,10,0,0"
         HorizontalAlignment="Center"
         Orientation="Horizontal"
         >
                    <TextBlock
             Width="100"
               Text="{x:Static lang:Resources.ConfigureCellRules}"
                 
             Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
             VerticalAlignment="Center"
             >


                    </TextBlock>
                    <Button
             Width="150"
             x:Name="SetBattery"
               Content="{x:Static lang:Resources.Configure}"
                 
                 Click="SetBattery_Click">

                    </Button>
                </StackPanel>
                <Button 
             Margin="0,10,0,0"
             
               Content="{x:Static lang:Resources.Delete}"
             
             x:Name="DeleteBtn" Click="DeleteBtn_Click" Width="100" HorizontalAlignment="Center"></Button>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
