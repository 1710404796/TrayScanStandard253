<Window x:Class="TrayScanStandard.View.CZPallet.ChannelModify"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
        mc:Ignorable="d"
        xmlns:ui="http://schemas.modernwpf.com/2019" 
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
        
        
        d:DataContext="{d:DesignInstance Type=local:ChannelModify}"
        ui:WindowHelper.UseModernWindowStyle="True"
        Loaded="Window_Loaded"
        Unloaded="Window_Unloaded"
         Title="{x:Static lang:Resources.ModifyChannelData}" Height="300" Width="600">
    <Grid>
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="Ti" FontSize="20" VerticalAlignment="Center" TextAlignment="Center"></TextBlock>
            <StackPanel  Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Width="50" VerticalAlignment="Center">ID:</TextBlock>
                <TextBlock Width="300" VerticalAlignment="Center" Text="{Binding Tid}"></TextBlock>
            </StackPanel>
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock
        Width="50" 
            Text="{x:Static lang:Resources.Barcode}"
        
        VerticalAlignment="Center">
                </TextBlock>
                <TextBox x:Name="CodeBox" Width="300" Text="{Binding StageChannel.Code, Mode=OneWay}"></TextBox>
            </StackPanel>
            <StackPanel Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Width="70" 
            Content="{x:Static lang:Resources.Save}"
            
            Click="Button_Click">
                </Button>
                <Button Width="70"
            Margin="20,0,0,0"
            Content="{x:Static lang:Resources.Cancel}"
            
            Click="Button_Click_1" >

                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
