<Window x:Class="TrayScanStandard.View.CZPallet.PalletRuleEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="TrayScanStandard.View.CZPallet"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
        mc:Ignorable="d"
                 xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Loaded="Window_Loaded"
        Unloaded="Window_Unloaded"
        d:DataContext="{d:DesignInstance Type=local:PalletRuleEditView}"
        Title="PalletRuleEditView" Height="600" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="70"/>

        </Grid.RowDefinitions>


        <Button
     x:Name="AddPallet"
     Click="AddPallet_Click"
               Content="{x:Static lang:Resources.CreateNewTrayBarcodeRule}"
     
     ></Button>
        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="PalletList">

            </StackPanel>
        </ScrollViewer>
        <Button
     Grid.Row="2"
     x:Name="Save"
     HorizontalAlignment="Center"
     Width="100"
               Content="{x:Static lang:Resources.Save}"
     
       Click="Save_Click"
     ></Button>
    </Grid>
</Window>
