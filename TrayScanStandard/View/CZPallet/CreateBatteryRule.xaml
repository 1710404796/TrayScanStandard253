<Window x:Class="TrayScanStandard.View.CZPallet.CreateBatteryRule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
        mc:Ignorable="d"
         xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
 
        Title="CreateBatteryRule" Height="250" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock
     FontSize="20"
                 Text="{x:Static lang:Resources.CreateNewRule}"
     
     >
        </TextBlock>
        <StackPanel Grid.Row="1">
            <StackPanel 
         Margin="0,10,0,0"
         Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock 
             VerticalAlignment="Center"
                 Text="{x:Static lang:Resources.RuleName}"
             
             Width="100"></TextBlock>
                <TextBox Width="150" x:Name="RuleName"></TextBox>


            </StackPanel>

            <StackPanel
         Margin="0,10,0,0"
         Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock 
                 Text="{x:Static lang:Resources.RegularExpression}"
             VerticalAlignment="Center"
             Width="100"></TextBlock>
                <TextBox Width="150" x:Name="RegexString"></TextBox>

            </StackPanel>

            <Button
         Width="100"
         Click="Button_Click" 
         Margin="0,20,0,0"
                
                        Content="{x:Static lang:Resources.Save}"
                
         HorizontalAlignment="Center"
         ></Button>
        </StackPanel>
    </Grid>
</Window>
