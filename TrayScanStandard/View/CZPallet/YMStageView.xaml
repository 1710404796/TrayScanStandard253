<UserControl x:Class="TrayScanStandard.View.CZPallet.YWStageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=local:YWStageView}"
             
             Loaded="UserControl_Loaded"
             
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock 
 FontSize="25"
     VerticalAlignment="Center"
         Text="{x:Static lang:Resources.OverallWorkstationStatus}"
     
 Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
            >

            </TextBlock>
            <Button x:Name="ClearAll" Margin="10,0,0,0" Click="ClearAll_Click">清空所有工位</Button>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1">

            <WrapPanel x:Name="GongWeiSim">
                <!--<local:GongWeiView
                Width="300"
                Height="300"
                ></local:GongWeiView>-->

            </WrapPanel>

        </ScrollViewer>
    </Grid>
</UserControl>
