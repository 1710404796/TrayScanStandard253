<Window x:Class="TrayScanStandard.View.CZPallet.BatteryRuleEdit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
        mc:Ignorable="d"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
                         xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        d:DataContext="{d:DesignInstance Type=local:BatteryRuleEdit}"
        Loaded="Window_Loaded"
        Unloaded="Window_Unloaded"
        
        Title="BatteryRuleEdit" Height="450" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>


        <Button
      x:Name="AddPallet"
      Click="AddPallet_Click"
      Content="{x:Static lang:Resources.CreateNewCellBarcodeRule}"

      ></Button>
        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="BatteryList">

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
