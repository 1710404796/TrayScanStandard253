<UserControl x:Class="TrayScanStandard.View.CZPallet.BatteryRuleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
             
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=local:BatteryRuleControl}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="10"
            BorderThickness="2"
            Margin="10"
                BorderBrush="{DynamicResource SystemControlPageTextBaseHighBrush}">

        <Grid Margin="10">
            <StackPanel HorizontalAlignment="Center">
                <StackPanel
          Margin="0,10,0,0"
          HorizontalAlignment="Center"
          Orientation="Horizontal"
          >
                    <TextBlock
              Width="100"
              Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
              VerticalAlignment="Center"
                  
                  Text="{x:Static lang:Resources.CellRuleName}"
              >

                    </TextBlock>
                    <TextBox
              Width="150"
              Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
              Text="{Binding Item.Name , Mode=OneTime}"
              x:Name="PalletRuleName"
              >

                    </TextBox>

                </StackPanel>
                <StackPanel
          Margin="0,10,0,0"
          HorizontalAlignment="Center"
          Orientation="Horizontal"
          >
                    <TextBlock
              Width="100"
              VerticalAlignment="Center"
                  Text="{x:Static lang:Resources.CellRegex}"
                  
              Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
              >
                    </TextBlock>
                    <TextBox
              Width="150"
              Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}" 
              Text="{Binding Item.BatteryRegex, Mode=OneTime}"
              x:Name="PalletRegex">

                    </TextBox>
                </StackPanel>


                <Button 
              Margin="0,10,0,0"
              x:Name="DeleteBtn"
              Click="DeleteBtn_Click"
              Width="100"
                  Content="{x:Static lang:Resources.Delete}"
              
              HorizontalAlignment="Center">

                </Button>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
