<Page x:Class="TrayScanStandard.View.CZPallet.PalletLogView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
      mc:Ignorable="d" 
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      Loaded="Page_Loaded"
      d:DataContext="{d:DesignInstance Type=local:PalletLogView}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="扫码日志界面">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="5">

            <Button Content="查询" Command="{Binding ViewModel.SearchCommand}"/>

            <DatePicker SelectedDate="{Binding ViewModel.StartTime}" Margin="10,0,0,0"/>

            <TextBlock 
                VerticalAlignment="Center" 
                Margin="10,0,0,0"
                Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="至"/>

            <DatePicker SelectedDate="{Binding ViewModel.EndTime}" Margin="10,0,0,0"/>

            <TextBlock 
                VerticalAlignment="Center" 
                Margin="10,0,0,0"
                Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="托盘条码"/>
            <TextBox 
                Width="150"
                Margin="10,0,0,0" 
                Text="{Binding ViewModel.Code}"
                VerticalContentAlignment="Center"/>

            <TextBlock 
                VerticalAlignment="Center" 
                Margin="10,0,0,0"
                Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="显示条目"/>
            <TextBox 
                Width="150" 
                Margin="10,0,0,0" 
                Text="{Binding ViewModel.LogNum}"
                VerticalContentAlignment="Center"/>

            <Button 
                Content="{x:Static lang:Resources.DeriveCVS}" 
                Margin="10,0,0,0"
                Command="{Binding ViewModel.ExportCommand}"/>

            <Button 
                Content="导出全部" 
                Margin="10,0,0,0"
                Command="{Binding ViewModel.ExportAllCommand}"/>

        </StackPanel>

        <DataGrid 
            Grid.Row="1" 
            CanUserAddRows="False"
            AutoGenerateColumns="False"
            ItemsSource="{Binding ViewModel.PalletLogs}">

            <DataGrid.Columns>

                <DataGridCheckBoxColumn Header="勾选" Binding="{Binding IsSelect}" IsReadOnly="False"/>

                <DataGridTextColumn Header="托盘条码" Binding="{Binding PalletCode}"/>
                
                <DataGridTextColumn Header="扫码时间" Binding="{Binding ZuPanTime}"/>
                
                <DataGridTextColumn Header="通道数量" Binding="{Binding ChannelCount}"/>
                
                <DataGridTextColumn Header="识别条码数" Binding="{Binding RealCount}"/>

                <!--<DataGridTextColumn Header="托盘信息" Binding="{Binding }" ></DataGridTextColumn>-->

                <DataGridTemplateColumn Header="托盘信息">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Button Content="托盘内容"
                                    Tag="{Binding }"  
                                    HorizontalAlignment="Stretch"
                                    Width="Auto"
                                    Click="Button_Click" />

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
