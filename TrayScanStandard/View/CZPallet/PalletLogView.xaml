<Page x:Class="TrayScanStandard.View.CZPallet.PalletLogView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View.CZPallet"
      mc:Ignorable="d" 
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      Loaded="Page_Loaded"
      d:DataContext="{d:DesignInstance Type=local:PalletLogView}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PalletLogView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="5">
            <Button Content="{x:Static lang:Resources.Query}"
 Command="{Binding ViewModel.SearchCommand}"/>
            <DatePicker SelectedDate="{Binding ViewModel.StartTime}" Margin="10,0,0,0"></DatePicker>
            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0"
               Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                Text="{x:Static lang:Resources.To}"
                       
    ></TextBlock>
            <DatePicker SelectedDate="{Binding ViewModel.EndTime}" Margin="10,0,0,0"></DatePicker>

            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0"
           Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                       
                Text="{x:Static lang:Resources.TrayBarcode}"
                       
></TextBlock>
            <TextBox Width="150" Margin="10,0,0,0" Text="{Binding ViewModel.Code}"
                     VerticalContentAlignment="Center"
                     
                     ></TextBox>

            <Button Content="{x:Static lang:Resources.DeriveCVS}" Margin="10,0,0,0"
Command="{Binding ViewModel.ExportCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" 
          CanUserAddRows="False"
          AutoGenerateColumns="False"
          ItemsSource="{Binding ViewModel.PalletLogs}"
>
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="{x:Static lang:Resources.Check}" Binding="{Binding IsSelect}" IsReadOnly="False"></DataGridCheckBoxColumn>
                <DataGridTextColumn Header="{x:Static lang:Resources.TrayBarcode}" Binding="{Binding PalletCode}" ></DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static lang:Resources.AssemblyTime}" Binding="{Binding ZuPanTime}"></DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static lang:Resources.ChannelCount}" Binding="{Binding ChannelCount}"></DataGridTextColumn>
                <!--<DataGridTextColumn Header="托盘信息" Binding="{Binding }" ></DataGridTextColumn>-->
                <DataGridTemplateColumn Header="{x:Static lang:Resources.TrayInformation}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{x:Static lang:Resources.TrayContents}"
                    Tag="{Binding }"  
                    HorizontalAlignment="Stretch"
                    Width="Auto"
                    Click="Button_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
