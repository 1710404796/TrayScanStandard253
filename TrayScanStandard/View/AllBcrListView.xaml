<Page x:Class="TrayScanStandard.View.AllBcrListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrayScanStandard.View"
      xmlns:lang="clr-namespace:TrayScanStandard.Properties"
      mc:Ignorable="d" 
      Loaded="Page_Loaded"
      Unloaded="Page_Unloaded"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AllBcrListView">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="40px"/>
            <RowDefinition Height="40px"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!--<StackPanel>
            <Button Width="150">添加一个扫码枪</Button>
        </StackPanel>-->
        <StackPanel Orientation="Horizontal">

            <TextBlock 
                   FontSize="24"
                   Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                   Text="相机界面"/>

            <Button Width="150" Margin="15,0,0,0" x:Name="AllCapture" Click="AllCapture_Click" Content="全部拍摄"/>

            <!--<Button Width="150" Margin="15,0,0,0" x:Name="ManualStart" Click="ManualStart_Click" Content="{x:Static lang:Resources.ManuallyStartDetection}"></Button>
            <Button Width="150" Margin="15,0,0,0" x:Name="ManualStop" Click="ManualStop_Click" Content="{x:Static lang:Resources.ManualShutdownDetection}"></Button>
            <Button Width="150" Margin="15,0,0,0" x:Name="DebugCapture" Click="DebugCapture_Click" Content="{x:Static lang:Resources.DebuggingQRCodeScanning}"></Button>
            <TextBox Width="150" Margin="15,0,0,0" Text="{Binding DebugExp}" VerticalContentAlignment="Center"></TextBox>
            <TextBlock FontSize="24" 
                       Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
                       Text="{x:Static lang:Resources.EnterExposureParameters}"/>-->

        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1">

            <Button  x:Name="Clear" Click="Clear_Click" Content="清楚调试数据"/>

            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" x:Name="Ratio" FontSize="24"/>

        </StackPanel>        
        
        <ScrollViewer Grid.Row="2">

            <Canvas x:Name="BcrPanel" Background="Transparent"/>

        </ScrollViewer>

    </Grid>
</Page>
